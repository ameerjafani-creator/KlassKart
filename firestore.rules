rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Products collection: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories collection: Anyone can read, only admin can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users collection: Owners can read/write their own, admin can read/write all
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Orders collection: Owners can read their own, users can create, admin can read/write all
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Coupons collection: Anyone can read (to validate), only admin can write
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
